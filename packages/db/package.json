{
  "name": "@sentinelqa/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "dotenv -e ../../.env -e ../../.env.example -- prisma generate",
    "db:push": "dotenv -e ../../.env -e ../../.env.example -- prisma db push && dotenv -e ../../.env -e ../../.env.example -- prisma generate",
    "db:seed": "dotenv -e ../../.env -e ../../.env.example -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@sentinelqa/dsl": "workspace:*",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
